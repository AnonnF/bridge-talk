# Local frontend → local API (npm run dev:full)
VITE_API_BASE_URL=http://localhost:3001

# Optional: override CORS for the Express server
# CORS_ORIGIN=http://localhost:5173

# Production on Vercel: leave VITE_API_BASE_URL unset so the app calls /api on the same host.

# Supabase — frontend (get from supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# Supabase — server-only (never expose to the browser)
# SUPABASE_URL mirrors VITE_SUPABASE_URL but is read by the Express server
SUPABASE_URL=https://your-project-id.supabase.co
# Service role key: supabase.com → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Counsellor invite code — share only with counsellors, set same value in Vercel env vars
COUNSELLOR_INVITE_CODE=your-invite-code-here
